.star-card {
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}
.star-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(120% 60% at 0% 0%, rgba(122,167,255,0.25), transparent 60%);
  pointer-events: none;
}
.star-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.star-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.star-card__extra {
  font-size: 24rpx;
  color: #C7D0EA;
}
.star-card__body { position: relative; }
