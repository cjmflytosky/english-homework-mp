<view class="page-container" wx:if="{{item}}">
  <view class="top-meta">
    <view class="top-meta__index">第 {{currentIndex + 1}} / {{totalCount}} 张</view>
    <view class="top-meta__type">左右滑动切换</view>
  </view>

  <!-- 卡片：左右滑动切换；点击卡片触发「（范读 →）嘟 → 录音」 -->
  <swiper
    class="card-swiper"
    current="{{currentIndex}}"
    bindchange="onSwiperChange"
    duration="280"
    easing-function="easeOutCubic">
    <swiper-item wx:for="{{items}}" wx:key="id" wx:for-item="card">
      <view class="swiper-card card" bindtap="onTapCard">
        <image
          wx:if="{{card.imageUrl}}"
          class="swiper-card__img"
          src="{{card.imageUrl}}"
          mode="aspectFit"/>
        <view wx:else class="swiper-card__empty">暂无配图</view>
      </view>
    </swiper-item>
  </swiper>

  <view class="word-card__hint text-muted">
    {{ phase === 'playing'   ? '正在播放范读…' :
       phase === 'beeping'   ? '嘟——准备录音…' :
       phase === 'recording' ? '正在录音…' :
       phase === 'recorded'  ? '录好了，可回放 / 重录' :
       phase === 'uploaded'  ? '已录过 ✓，可回放 / 重录' :
       '点击卡片或下方按钮开始跟读' }}
  </view>

  <!-- 录音状态区 -->
  <view class="rec-zone card">
    <block wx:if="{{phase === 'recording'}}">
      <view class="rec-live__timer">{{elapsedSec}}s / {{maxSec}}s</view>
      <view class="rec-live__stop" bindtap="onStopRecord">结束录音</view>
    </block>

    <view wx:elif="{{phase === 'recorded' || phase === 'uploaded'}}" class="rec-actions">
      <view class="rec-action" bindtap="onPlayback">▶ 回放</view>
      <view class="rec-action" bindtap="onReRecord">↺ 重录</view>
    </view>

    <view wx:elif="{{phase === 'stopping'}}" class="rec-status text-soft">处理中…</view>

    <view wx:elif="{{phase === 'playing' || phase === 'beeping'}}" class="rec-status text-muted">请仔细听…</view>

    <view wx:else class="rec-start" bindtap="onStartRecord">● 开始录音</view>

    <view wx:if="{{phase === 'error'}}" class="rec-error">{{errorMsg}}</view>
  </view>

  <view class="progress-row text-soft">
    已录 <text class="text-accent">{{doneCount}}</text> / {{totalCount}} 张
  </view>

  <view
    wx:if="{{doneCount >= totalCount}}"
    class="finalize-btn {{submitting ? 'is-loading' : ''}}"
    bindtap="goFinalize">{{submitting ? '提交中…' : '整体提交'}}</view>
</view>

<view wx:else class="page-container text-soft">加载中…</view>
