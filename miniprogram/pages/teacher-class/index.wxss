.page-container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f7f8fc;
}

.header { margin-bottom: 24rpx; }
.header__title { font-size: 40rpx; font-weight: 600; color: #1a1f36; }
.header__meta  { font-size: 26rpx; margin-top: 8rpx; }

.stats {
  display: flex;
  padding: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}
.stat { flex: 1; text-align: center; }
.stat__num   { font-size: 38rpx; font-weight: 600; color: #1a1f36; }
.stat__label { font-size: 22rpx; margin-top: 4rpx; }
.stat--highlight .stat__num { color: #ff8a3d; }

.empty { padding: 80rpx 0; text-align: center; }

.row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
}
.row--pending { border-left: 6rpx solid #ff8a3d; }

.row__avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f2f7;
}
.row__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #7e8ab3;
  font-weight: 600;
}

.row__main { flex: 1; }
.row__name { font-size: 30rpx; font-weight: 500; color: #1a1f36; }
.row__no   { font-size: 22rpx; margin-top: 4rpx; }

.row__status {
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: #f0f2f7;
  color: #7e8ab3;
}
.row__status--pending { background: #fff1e6; color: #ff8a3d; font-weight: 600; }
.row__status--done    { background: #e6f9ed; color: #2ec27e; }
.row__status--draft   { background: #fff7d6; color: #b88500; }
.row__status--idle    { background: #f0f2f7; color: #a0a7be; }
