<view class="page-container">
  <view class="header">
    <view class="header__title">{{className || '班级'}}</view>
    <view class="header__sub text-soft">
      <text>{{grade || '未设年级'}}</text>
      <text class="dot">·</text>
      <text>口令 {{inviteCode}}</text>
      <text class="dot">·</text>
      <text>{{members.length}} 名学生</text>
    </view>
  </view>

  <view wx:if="{{loading && members.length === 0}}" class="empty text-soft">加载中…</view>
  <view wx:if="{{!loading && members.length === 0}}" class="empty text-soft">
    本班还没有学生，可在「学生管理」里把学生加入班级
  </view>

  <view wx:for="{{members}}" wx:key="memberId" class="row">
    <image
      wx:if="{{item.student.avatar}}"
      class="row__avatar"
      src="{{item.student.avatar}}" />
    <view wx:else class="row__avatar row__avatar--placeholder">
      {{item.student.realName || item.student.nickname || '?'}}
    </view>

    <view class="row__main">
      <view class="row__name">
        {{item.student.realName || item.student.nickname || '未命名'}}
        <text
          wx:if="{{item.student.role !== 'STUDENT'}}"
          class="role-badge role-badge--{{item.student.role}}">{{item.roleLabel}}</text>
      </view>
      <view class="row__meta text-soft">{{item.student.studentNo || '未设学号'}}</view>
    </view>

    <view
      class="op-btn op-btn--del"
      data-memberid="{{item.memberId}}"
      data-name="{{item.student.realName || item.student.nickname || '该学生'}}"
      bindtap="onRemove">移出</view>
  </view>
</view>
