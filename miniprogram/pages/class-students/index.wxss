.page-container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f7f8fc;
}

.header { margin-bottom: 24rpx; }
.header__title { font-size: 40rpx; font-weight: 600; color: #1a1f36; }
.header__sub {
  font-size: 24rpx;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.text-soft { color: #7e8ab3; }
.dot { margin: 0 8rpx; }

.empty { padding: 80rpx 0; text-align: center; }

.row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
}
.row__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f2f7;
}
.row__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #7e8ab3;
  font-weight: 600;
}
.row__main { flex: 1; min-width: 0; }
.row__name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1f36;
  display: flex;
  align-items: center;
}
.row__meta { font-size: 22rpx; margin-top: 6rpx; }

.role-badge {
  margin-left: 12rpx;
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}
.role-badge--TEACHER { background: #e6f1ff; color: #3d6bff; }
.role-badge--ADMIN   { background: #ffe6e6; color: #ff3d6b; font-weight: 600; }

.op-btn {
  font-size: 22rpx;
  padding: 10rpx 22rpx;
  border-radius: 8rpx;
  text-align: center;
}
.op-btn--del { background: #ffe6ec; color: #ff3d6b; }
