.hint { font-size: 26rpx; margin-bottom: 20rpx; }
.empty { text-align: center; padding: 60rpx 0; font-size: 26rpx; }

.hw-card {
  display: flex; align-items: center;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.12);
}
.hw-card--on {
  border-color: #3D6BFF;
  background: rgba(61,107,255,0.16);
}
.hw-card__main { flex: 1; }
.hw-card__title { font-size: 30rpx; font-weight: 600; }
.hw-card__meta { font-size: 24rpx; margin-top: 8rpx; }
.hw-card__check {
  width: 48rpx; text-align: center;
  font-size: 36rpx; color: #7AA7FF;
}

.publish-zone { margin-top: 16rpx; padding: 32rpx; }
.publish-zone__title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }
.form-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 2rpx solid rgba(255,255,255,0.08);
}
.form-row__label { font-size: 28rpx; color: #C7D0EA; }
.picker-val { font-size: 30rpx; color: #FFFFFF; }

.actions { margin-top: 32rpx; }
