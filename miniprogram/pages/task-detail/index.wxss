.hero { margin-bottom: 24rpx; }
.hero__title { font-size: 40rpx; font-weight: 700; }
.hero__meta {
  margin-top: 12rpx; font-size: 26rpx;
  display: flex; align-items: center; gap: 10rpx;
}
.dot { opacity: 0.5; }
.desc { font-size: 26rpx; line-height: 1.7; }
.section-title {
  font-size: 28rpx; font-weight: 600;
  color: #C7D0EA;
  margin: 16rpx 0 12rpx;
  letter-spacing: 2rpx;
}

.item {
  position: relative;
  display: flex; align-items: flex-start; gap: 20rpx;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  padding: 24rpx 56rpx 24rpx 24rpx;
  margin-bottom: 16rpx;
}
.item__no {
  flex-shrink: 0;
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,#7AA7FF,#3D6BFF);
  color: #fff; font-size: 24rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.item__body { flex: 1; }
.item__text { font-size: 28rpx; line-height: 1.5; color: #FFFFFF; }
.item__tr { font-size: 24rpx; margin-top: 8rpx; }
.item__arrow {
  position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%);
  font-size: 40rpx; color: rgba(255,255,255,0.35);
}
