.field-input {
  height: 72rpx;
  padding: 0 8rpx;
  font-size: 30rpx;
  color: #FFFFFF;
}
.field-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 8rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  line-height: 1.6;
  color: #FFFFFF;
}

/* 录音区 */
.rec-zone {
  padding: 12rpx 0 4rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center;
}
.rec-start {
  padding: 18rpx 56rpx; border-radius: 999rpx;
  background: linear-gradient(135deg, #FF7AA7, #FF3D6B);
  color: #fff; font-size: 28rpx; font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(255,61,107,0.45);
}
.rec-live__timer { font-size: 40rpx; font-weight: 700; color: #FFFFFF; }
.rec-live__stop {
  margin-top: 18rpx;
  padding: 14rpx 44rpx; border-radius: 999rpx;
  background: linear-gradient(135deg, #FFD27A, #FF8A3D);
  color: #fff; font-size: 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(255,138,61,0.4);
}
.rec-actions { display: flex; gap: 20rpx; justify-content: center; flex-wrap: wrap; }
.rec-action {
  padding: 14rpx 32rpx; border-radius: 999rpx;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.16);
  color: #C7D0EA; font-size: 26rpx;
}
.rec-action--primary {
  background: linear-gradient(135deg, #7AA7FF, #3D6BFF);
  color: #fff; border: none;
  box-shadow: 0 10rpx 24rpx rgba(61,107,255,0.4);
}
.rec-action--done { color: #7AD4A7; border-color: rgba(122,212,167,0.4); }
.rec-status { font-size: 26rpx; }
.rec-error { margin-top: 12rpx; font-size: 24rpx; color: #F08A8A; }
.rec-meta { margin-top: 12rpx; font-size: 22rpx; }

/* 派发步骤 */
.created-tip {
  display: flex; align-items: center; gap: 20rpx;
  padding: 28rpx 32rpx;
}
.created-tip__check {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: linear-gradient(135deg, #7AD4A7, #3DBF8B);
  color: #fff; font-size: 32rpx;
  display: flex; align-items: center; justify-content: center;
}
.created-tip__text { font-size: 28rpx; color: #C7D0EA; }

.picker-row {
  display: flex; justify-content: space-between; align-items: center;
  height: 72rpx; font-size: 30rpx; color: #FFFFFF;
}
.picker-row__arrow { color: #7AA7FF; }

.actions { margin-top: 40rpx; }
.skip-link {
  margin-top: 24rpx; text-align: center;
  font-size: 26rpx; color: #7AA7FF;
}
