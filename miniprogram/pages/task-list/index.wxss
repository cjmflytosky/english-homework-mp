.header { margin-bottom: 24rpx; }
.empty { text-align: center; padding: 80rpx 0; }

.task-card {
  position: relative;
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,255,255,0.14);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
}
.task-card__row {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 10rpx;
}
.task-card__title {
  font-size: 30rpx; font-weight: 600; color: #FFFFFF;
  max-width: 480rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.task-card__meta {
  font-size: 24rpx;
  display: flex; align-items: center; gap: 8rpx;
}
.dot { opacity: 0.5; }
.task-card__arrow {
  position: absolute;
  right: 28rpx; top: 50%; transform: translateY(-50%);
  font-size: 40rpx; color: rgba(255,255,255,0.4);
}

.badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(122,167,255,0.2);
  color: #7AA7FF;
}
.badge--PENDING     { color: #C7D0EA; background: rgba(255,255,255,0.10); }
.badge--IN_PROGRESS { color: #7AA7FF; background: rgba(122,167,255,0.18); }
.badge--SUBMITTED   { color: #6DE1B8; background: rgba(109,225,184,0.15); }
.badge--EXPIRED     { color: #F08A8A; background: rgba(240,138,138,0.15); }
