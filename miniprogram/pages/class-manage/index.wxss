.page-container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f7f8fc;
}

.header { margin-bottom: 24rpx; }
.header__title { font-size: 40rpx; font-weight: 600; color: #1a1f36; }
.header__sub   { font-size: 26rpx; margin-top: 8rpx; }
.text-soft { color: #7e8ab3; }

.create-btn {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #3d6bff;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(61, 107, 255, 0.3);
}

.empty { padding: 80rpx 0; text-align: center; }

.row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
}
.row__main { flex: 1; min-width: 0; }
.row__name { font-size: 30rpx; font-weight: 500; color: #1a1f36; }
.row__meta {
  font-size: 22rpx;
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.dot { margin: 0 8rpx; }

.row__actions { display: flex; flex-direction: column; gap: 8rpx; }
.op-btn {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  text-align: center;
}
.op-btn--edit { background: #e6f1ff; color: #3d6bff; }
.op-btn--del  { background: #ffe6ec; color: #ff3d6b; }

/* ---------------- 表单弹层 ---------------- */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(10, 18, 56, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 50;
}
.sheet {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx 32rpx calc(36rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
.sheet__title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1f36;
  margin-bottom: 24rpx;
  text-align: center;
}

.field { margin-bottom: 24rpx; }
.field__label { font-size: 26rpx; color: #7e8ab3; margin-bottom: 10rpx; }
.field__input {
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  background: #f4f6fb;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1a1f36;
}

.sheet__actions {
  display: flex;
  gap: 20rpx;
  margin-top: 12rpx;
}
.sheet-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.sheet-btn--ghost { background: #f0f2f7; color: #4a5578; }
.sheet-btn--primary { background: #3d6bff; color: #fff; }
.sheet-btn--primary.is-disabled { opacity: 0.6; }
