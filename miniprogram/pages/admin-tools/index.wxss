.page-container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f7f8fc;
}

.header { margin-bottom: 32rpx; }
.header__title { font-size: 40rpx; font-weight: 600; color: #1a1f36; }
.header__sub   { font-size: 26rpx; margin-top: 8rpx; }

.search-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.search-input {
  flex: 1;
  padding: 20rpx 28rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}
.search-btn {
  background: #3d6bff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  padding: 0 32rpx;
}

.empty { padding: 80rpx 0; text-align: center; }

.row {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
}
.row__avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f2f7;
}
.row__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #7e8ab3;
  font-weight: 600;
}
.row__main { flex: 1; min-width: 0; }
.row__name { font-size: 30rpx; font-weight: 500; color: #1a1f36; }
.row__meta { font-size: 22rpx; margin-top: 6rpx; display: flex; align-items: center; }
.dot { margin: 0 8rpx; }

.role-badge {
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}
.role-badge--STUDENT { background: #f0f2f7; color: #7e8ab3; }
.role-badge--TEACHER { background: #e6f1ff; color: #3d6bff; }
.role-badge--ADMIN   { background: #ffe6e6; color: #ff3d6b; font-weight: 600; }

.row__actions { display: flex; flex-direction: column; gap: 8rpx; }
.op-btn {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  text-align: center;
}
.op-btn--role  { background: #fff1e6; color: #ff8a3d; }
.op-btn--class { background: #e6f1ff; color: #3d6bff; }
