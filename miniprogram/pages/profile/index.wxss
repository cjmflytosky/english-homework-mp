.profile-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 8rpx 32rpx;
}
.profile-hero__avatar {
  width: 128rpx; height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,#7AA7FF,#3D6BFF);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 54rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(61,107,255,0.45);
}
.profile-hero__avatar image { width: 100%; height: 100%; }
.profile-hero__info .name { font-size: 36rpx; font-weight: 600; }
.profile-hero__info .meta { font-size: 24rpx; margin-top: 8rpx; }

.kv {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.kv:last-child { border-bottom: none; }
.kv__k { font-size: 26rpx; }
.kv__v { font-size: 26rpx; max-width: 60%; text-align: right; word-break: break-all; }

.entries {
  margin: 24rpx 0 32rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.12);
  border-radius: 24rpx;
  overflow: hidden;
}
.entry {
  display: flex; align-items: center;
  padding: 24rpx 28rpx;
}
.entry__icon { font-size: 36rpx; width: 56rpx; }
.entry__label { flex: 1; font-size: 28rpx; color: #FFFFFF; }
.entry__arrow { font-size: 36rpx; color: rgba(255,255,255,0.4); }

.cls {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}
.cls:last-of-type { border-bottom: none; }
.cls__name { font-size: 28rpx; color: #fff; font-weight: 600; }
.cls__meta { font-size: 24rpx; margin-top: 6rpx; }
.empty { padding: 12rpx 0 16rpx; }
.muted { color: #8B97C4; font-size: 26rpx; }
.muted-sub { color: #8B97C4; font-size: 24rpx; margin-top: 8rpx; }
