<view class="page-container">
  <view class="hero">
    <view class="hero__label text-soft">{{roleLabel}}端</view>
    <view class="hero__name">{{nickname}}</view>
  </view>

  <view wx:if="{{isAdmin}}" class="admin-shortcut" bindtap="goAdminTools">
    <view class="admin-shortcut__icon">👥</view>
    <view class="admin-shortcut__text">
      <view class="admin-shortcut__title">学生管理</view>
      <view class="admin-shortcut__desc text-soft">全部学生 · 升降级 · 加入班级</view>
    </view>
    <view class="admin-shortcut__arrow">›</view>
  </view>

  <view wx:if="{{isAdmin}}" class="admin-shortcut" bindtap="goClassManage">
    <view class="admin-shortcut__icon">🏫</view>
    <view class="admin-shortcut__text">
      <view class="admin-shortcut__title">班级管理</view>
      <view class="admin-shortcut__desc text-soft">新建 · 编辑 · 删除班级</view>
    </view>
    <view class="admin-shortcut__arrow">›</view>
  </view>

  <view class="admin-shortcut" bindtap="goAssignWordCard">
    <view class="admin-shortcut__icon">🃏</view>
    <view class="admin-shortcut__text">
      <view class="admin-shortcut__title">布置单词跟读</view>
      <view class="admin-shortcut__desc text-soft">选预置单元 · 派发给班级</view>
    </view>
    <view class="admin-shortcut__arrow">›</view>
  </view>

  <view class="admin-shortcut" bindtap="goCreateHomework">
    <view class="admin-shortcut__icon">🎙️</view>
    <view class="admin-shortcut__text">
      <view class="admin-shortcut__title">布置长句作业</view>
      <view class="admin-shortcut__desc text-soft">录一句话 · 学生跟读</view>
    </view>
    <view class="admin-shortcut__arrow">›</view>
  </view>

  <view class="section-title">待批改作业</view>

  <view class="tabs">
    <view
      class="tab {{tab === 'pending' ? 'tab--on' : ''}}"
      data-tab="pending"
      bindtap="switchTab">待批改</view>
    <view
      class="tab {{tab === 'done' ? 'tab--on' : ''}}"
      data-tab="done"
      bindtap="switchTab">已批完</view>
    <view
      class="tab {{tab === 'all' ? 'tab--on' : ''}}"
      data-tab="all"
      bindtap="switchTab">全部</view>
  </view>

  <view wx:if="{{assignmentsLoading && assignments.length === 0}}" class="text-soft empty">加载中…</view>
  <view wx:if="{{!assignmentsLoading && assignments.length === 0}}" class="text-soft empty">
    {{tab === 'pending' ? '没有待批改的作业 🎉' : tab === 'done' ? '还没有已批完的作业' : '暂无作业'}}
  </view>

  <view
    wx:for="{{assignments}}"
    wx:key="id"
    class="assignment-card"
    data-id="{{item.id}}"
    bindtap="goAssignment">
    <view class="assignment-card__head">
      <view class="assignment-card__title">{{item.homework.title}}</view>
      <view
        wx:if="{{item.statusLabel}}"
        class="grade-tag grade-tag--{{item.gradingStatus}}">{{item.statusLabel}}</view>
    </view>
    <view class="assignment-card__meta text-soft">
      <text>{{item.class.name}}</text>
      <text class="dot">·</text>
      <text>{{item.homework.type === 'REPEAT' ? '跟读' : '背诵'}}</text>
      <text class="dot">·</text>
      <text>截止 {{item.dueLabel}}</text>
    </view>
  </view>

  <view wx:if="{{assignments.length > 0}}" class="list-footer text-soft">
    <text wx:if="{{assignmentsLoading}}">加载中…</text>
    <text wx:elif="{{!assignmentsMore}}">没有更多了</text>
  </view>

  <view class="section-title">我管理的班级（{{classes.length}}）</view>

  <view wx:if="{{!loading && classes.length === 0}}" class="text-soft empty">
    暂无班级。{{isAdmin ? '可在管理员工具里创建/查看。' : '请联系管理员把你加到班级。'}}
  </view>

  <view
    wx:for="{{classes}}"
    wx:key="id"
    class="class-card"
    data-id="{{item.id}}"
    data-name="{{item.name}}"
    bindtap="goClass">
    <view class="class-card__main">
      <view class="class-card__name">{{item.name}}</view>
      <view class="class-card__meta text-soft">
        <text>{{item.grade || '未设年级'}}</text>
        <text class="dot">·</text>
        <text>口令 {{item.inviteCode}}</text>
      </view>
    </view>
    <view class="class-card__arrow">›</view>
  </view>

  <view class="actions">
    <star-button type="ghost" bindtap="onLogout">退出登录</star-button>
  </view>
</view>
