.page-container {
  padding: 32rpx;
  min-height: 100vh;
  background: #f7f8fc;
}

.hero {
  padding: 48rpx 32rpx;
  background: linear-gradient(135deg, #3d6bff, #6b8eff);
  border-radius: 24rpx;
  color: #fff;
  margin-bottom: 32rpx;
}

.hero__label {
  font-size: 24rpx;
  opacity: 0.8;
}

.hero__name {
  font-size: 48rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

.placeholder {
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
}

.placeholder__title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1f36;
  margin-bottom: 16rpx;
}

.placeholder__desc {
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-line;
}

.actions {
  margin-top: 48rpx;
}
