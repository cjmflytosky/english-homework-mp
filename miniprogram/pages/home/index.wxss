.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.hero__hi { font-size: 44rpx; font-weight: 700; }
.hero__date { font-size: 24rpx; color: #C7D0EA; margin-top: 8rpx; }

.hero__avatar {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg,#7AA7FF,#3D6BFF);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 10rpx 24rpx rgba(61,107,255,0.45);
  overflow: hidden;
}
.hero__avatar image { width: 100%; height: 100%; }

.progress__bar {
  height: 12rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}
.progress__fill {
  height: 100%;
  background: linear-gradient(90deg, #7AA7FF, #3D6BFF);
}
.progress__meta { font-size: 24rpx; }

.quick-row { display: flex; justify-content: space-around; }
.quick-item { text-align: center; flex: 1; }
.quick-item__icon {
  font-size: 48rpx;
  width: 96rpx; height: 96rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.10);
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 12rpx;
}
.quick-item__label { font-size: 24rpx; color: #C7D0EA; }

.tip-text { font-size: 26rpx; color: #E9F0FF; line-height: 1.6; }
