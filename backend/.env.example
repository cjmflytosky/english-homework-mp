# ============== 通用 ==============
NODE_ENV=development
PORT=3000
APP_GLOBAL_PREFIX=api

# ============== 数据库 (MySQL) ==============
# 格式：mysql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="mysql://root:root@127.0.0.1:3306/xc_homework"

# ============== JWT ==============
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ============== 微信小程序 ==============
WECHAT_APPID=wx349b23c8e1fb7885
WECHAT_SECRET=your-wechat-app-secret
# 是否启用 mock 登录：true 时无需真实 code，code 以 mock- 开头即可登录
WECHAT_MOCK_LOGIN=true

# ============== 腾讯云 COS (录音文件存储) ==============
# MVP 阶段先 mock，正式接入时填写下方
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_MOCK=true

# ============== 腾讯云 SOE (语音评测) ==============
SOE_SECRET_ID=
SOE_SECRET_KEY=
SOE_REGION=ap-guangzhou
SOE_APP_ID=
# MVP 阶段直接返回 mock 评分
SOE_MOCK=true
